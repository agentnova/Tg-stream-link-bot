# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env — it is gitignored for safety.

# --- Telegram API (https://my.telegram.org -> API development tools) ---
API_ID=123456
API_HASH=your_api_hash_here

# --- Bot token from @BotFather ---
BOT_TOKEN=123456:ABC-your-bot-token

# --- Private storage channel id (bot must be ADMIN). Format: -100xxxxxxxxxx ---
STORAGE_CHANNEL_ID=-1001234567890

# --- Public URL where your reverse proxy serves this bot ---
#     e.g. https://stream.example.com  (Tailscale + Caddy, Cloudflare Tunnel, etc.)
PUBLIC_BASE_URL=http://stream.example.com

# --- Web server (internal; your reverse proxy points here) ---
BIND_ADDRESS=0.0.0.0
PORT=8082

# --- Optional tuning ---
WORKERS=4
CACHE_TTL=1800
# Chunks to fetch ahead of the player for smoother playback (~1 MiB each).
# Higher = smoother on slow links but more memory per stream. 3 is a good start.
PREFETCH_CHUNKS=3
